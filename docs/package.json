{
  "name": "@element-plus/docs",
  "private": true,
  "scripts": {
    "dev": "pnpm gen-locale && pnpm check-locale && vitepress dev .",
    "build": "pnpm gen-locale && pnpm check-locale && pnpm gen-llms && pnpm vitepress:build",
    "serve": "NODE_ENV=production vitepress serve . --port 5001",
    "vitepress:build": "node --max-old-space-size=8192 ./node_modules/vitepress/dist/node/cli.js build .",
    "gen-llms": "tsx .vitepress/build/generate-llms.ts",
    "gen-locale": "rimraf .vitepress/i18n && tsx .vitepress/build/crowdin-generate.ts",
    "check-locale": "tsx .vitepress/build/check-locales.ts",
    "crowdin-credentials": "tsx .vitepress/build/crowdin-credentials.ts"
  },
  "dependencies": {
    "@docsearch/css": "^3.1.0",
    "@docsearch/js": "^3.1.0",
    "@element-plus/icons-vue": "^2.3.2",
    "@element-plus/metadata": "workspace:*",
    "@vue/shared": "^3.5.22",
    "@vueuse/core": "12.0.0",
    "clipboard-copy": "^4.0.1",
    "element-plus": "npm:element-plus@latest",
    "markdown-it": "^14.1.0",
    "normalize.css": "^8.0.1",
    "nprogress": "^0.2.0"
  },
  "devDependencies": {
    "@crowdin/cli": "^4.5.0",
    "@element-plus/build": "workspace:*",
    "@element-plus/build-constants": "workspace:*",
    "@element-plus/build-utils": "workspace:*",
    "@iconify-json/ri": "^1.1.3",
    "@mdit-vue/shared": "^2.1.3",
    "@prettier/sync": "^0.6.1",
    "@vitejs/plugin-vue-jsx": "^4.0.1",
    "consola": "^2.15.3",
    "markdown-it-container": "^4.0.0",
    "tinyglobby": "^0.2.15",
    "unocss": "^66.5.6",
    "unplugin-icons": "^0.14.15",
    "unplugin-vue-components": "^0.27.4",
    "vite-plugin-inspect": "^0.8.7",
    "vite-plugin-mkcert": "^1.17.6",
    "vitepress": "^1.2.3",
    "vitepress-plugin-group-icons": "^1.7.1",
    "vue": "^3.5.22"
  }
}
